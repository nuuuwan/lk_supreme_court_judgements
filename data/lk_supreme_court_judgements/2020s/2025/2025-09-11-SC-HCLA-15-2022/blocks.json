    "page_number": 4,
    "bbox": [
      54.25,
      653.22,
      544.93,
      667.64
    ],
    "text": "remuneration has to be guided by his adjudicatory powers of ascertaining the veracity of",
    "fonts": [
      "CenturySchoolbook"
    ],
