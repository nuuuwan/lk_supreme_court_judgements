      "Calisto MT",
      "Calisto MT,BoldItalic"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 5,
    "bbox": [
      72.02,
      242.15,
      526.14,
      255.77
    ],
    "text": "relying on the dicta in Henaka Rallage Deepika Damayanthi v. Ranjith Ariyaratne, Post",
    "fonts": [
      "Calisto MT",
      "Calisto MT,BoldItalic"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 5,
    "bbox": [
      72.02,
      263.27,
      526.31,
      276.89
    ],
    "text": "Master General and Others (SC/FR/438/21, SC Minutes of 3 October 2024), the",
    "fonts": [
      "Calisto MT",
      "Calisto MT,BoldItalic"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 5,
    "bbox": [
      72.02,
      284.51,
      526.46,
      298.13
    ],
