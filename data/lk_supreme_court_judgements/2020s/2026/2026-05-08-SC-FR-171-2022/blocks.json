      "Calisto MT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      72.02,
      565.6,
      526.16,
      579.22
    ],
    "text": "Ranger for a period of six months by letter dated 07 May 2019 issued by the said DG.",
    "fonts": [
      "Calisto MT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      72.02,
      586.36,
      526.34,
      599.98
    ],
