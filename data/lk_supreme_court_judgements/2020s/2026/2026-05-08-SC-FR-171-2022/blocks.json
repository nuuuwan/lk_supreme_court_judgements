      "Calisto MT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 5,
    "bbox": [
      72.02,
      179.12,
      526.44,
      192.74
    ],
    "text": "The Respondents relied on judicial authorities (Gamaethige v Siriwardane [1998] 1 Sri LR",
    "fonts": [
      "Calisto MT",
      "Calisto MT,BoldItalic"
