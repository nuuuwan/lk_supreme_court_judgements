    "bbox": [
      72.02,
      125.96,
      526.13,
      139.58
    ],
    "text": "Ranger Grade III, by letter dated 31 January 2022 (marked \u2018X9a\u2019) issued by the Director",
    "fonts": [
      "Calisto MT"
    ],
    "sizes": [
      12.0
    ]
  },
