    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      126.02,
      125.48,
      526.21,
      139.1
    ],
    "text": "subjects (excluding the General Aptitude Test) at the G.C.E. A/L under the",
