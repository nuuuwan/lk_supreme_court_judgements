      "Calisto MT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      72.02,
      628.12,
      155.36,
      641.74
    ],
    "text": "(marked \u2018X8a\u2019).",
    "fonts": [
      "Calisto MT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      72.02,
      660.64,
      526.36,
      674.26
    ],
