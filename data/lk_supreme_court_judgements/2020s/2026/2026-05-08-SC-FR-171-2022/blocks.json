    "fonts": [
      "Calisto MT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 4,
    "bbox": [
      72.02,
      621.88,
      526.46,
      635.5
    ],
    "text": "who are permanently released or who relinquish their posts to accept another post,",
    "fonts": [
      "Calisto MT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 4,
    "bbox": [
      72.02,
      642.64,
      526.19,
      656.26
    ],
