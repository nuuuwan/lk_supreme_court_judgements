      72.02,
      483.37,
      542.92,
      496.99
    ],
    "text": "The instant Application was taken up for hearing together with the case bearing No.",
    "fonts": [
      "Calisto MT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
