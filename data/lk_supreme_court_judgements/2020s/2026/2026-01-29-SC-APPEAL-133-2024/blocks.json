      108.02,
      446.65,
      526.26,
      461.11
    ],
    "text": "High Court of the Provinces (holden in Badulla) on the following question of",
    "fonts": [
      "BookAntiqua"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 1,
    "bbox": [
      108.02,
      468.99,
      133.58,
      483.45
    ],
