    "fonts": [
      "Bookman Old Style"
    ],
    "sizes": [
      8.039999961853027,
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      72.02,
      387.03,
      269.09,
      401.03
    ],
    "text": "Argued on : 26.01.2026",
    "fonts": [
      "Bookman Old Style",
