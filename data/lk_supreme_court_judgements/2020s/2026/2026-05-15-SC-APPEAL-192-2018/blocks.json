    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 4,
    "bbox": [
      72.02,
      514.81,
      526.47,
      528.43
    ],
    "text": "Ayurvedic Physician Kularatne since 1973. Documentary evidence further reveals that",
